# RedEye -- environment variables
#
# Copy this file to `.env` and fill in only what your chosen profile needs.
# `.env` is loaded automatically by walking up parent directories from $PWD.
# Variables you export in your shell take precedence over `.env`.

# =============================================================================
# Backend: cli (Claude Code CLI) -- used by the default profile
# =============================================================================
# Either run `claude login` interactively, OR generate a long-lived token with
# `claude setup-token` and export it here:
# CLAUDE_CODE_OAUTH_TOKEN=

# Enterprise gateway extras (only if your org routes Claude through a gateway):
# ANTHROPIC_BASE_URL=https://your-gateway.example.com
# NODE_EXTRA_CA_CERTS=/path/to/private-ca.pem
# CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# =============================================================================
# Backend: sdk (Anthropic SDK)
# =============================================================================
# ANTHROPIC_SDK_API_KEY=sk-ant-...
# ANTHROPIC_SDK_BASE_URL=https://your-gateway.example.com    # optional
# ANTHROPIC_SDK_CA_CERT=/path/to/ca.pem                      # optional, mTLS
# ANTHROPIC_SDK_CLIENT_CERT=/path/to/client.pem              # optional, mTLS

# =============================================================================
# Backend: openai (OpenAI / OpenAI-compatible)
# =============================================================================
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1                  # or your gateway

# =============================================================================
# Backend: bedrock (AWS Bedrock -- Claude on AWS)
# =============================================================================
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...                                      # optional, for SSO/STS
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-opus-4-5-20251101-v1:0   # default

# =============================================================================
# Backend: vertex (Google Cloud Vertex AI -- Gemini)
# =============================================================================
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json            # service account key file
# GEMINI_MODEL=gemini-2.5-pro                                # default

# =============================================================================
# Backend: ollama (local Ollama server)
# =============================================================================
# OLLAMA_BASE_URL=http://localhost:11434                     # default
# OLLAMA_MODEL=qwen2.5-coder:14b                             # default

# =============================================================================
# Optional integrations
# =============================================================================
# Webhook notifications (Slack/Teams/Discord/generic)
# REDEYE_WEBHOOK_URL=https://hooks.slack.com/services/...
# REDEYE_WEBHOOK_SECRET=                                    # optional, for HMAC
# REDEYE_WEBHOOK_TYPE=slack                                 # slack|teams|discord|generic

# Findings database (SQLite by default; Databricks roadmap)
# REDEYE_DB_PATH=~/.redeye/scans.db
# REDEYE_STORE_FINDINGS=1                                   # 0/1

# GitHub PR comment posting (used by the GitHub Actions workflow)
# GITHUB_TOKEN=                                              # auto-populated in Actions

# Custom prompt extension (path to a Markdown file appended to system prompts)
# REDEYE_CUSTOM_PROMPT_FILE=./custom-prompt.md

# =============================================================================
# Harness behavior (rarely changed)
# =============================================================================
# REDEYE_LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR
# REDEYE_PROFILE=default        # default | cli | full | mock
# REDEYE_NO_NETWORK=0           # set to 1 to refuse any backend that needs net
