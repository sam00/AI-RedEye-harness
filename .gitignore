# Scan output (do not commit findings). Anchored to the repo root with a
# leading slash so they DO NOT shadow legitimate source directories with the
# same name (e.g. `redeye/output/` is the emitters package, not scan output).
/out/
/output/
/scans/
/security-scan/
*_report.md
*_report.sarif
*_errors.jsonl
run_manifest.json
# Re-include Python source under directories whose name collides with the
# scan-output anchors above. Only `.py` and `.md` files so that local
# __pycache__/ under these dirs stays ignored.
!redeye/output/**/*.py
!redeye/skills/prompts/**/*.md
